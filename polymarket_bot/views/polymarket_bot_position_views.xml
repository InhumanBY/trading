<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_polymarket_position_list" model="ir.ui.view">
        <field name="name">polymarket_bot.position.list</field>
        <field name="model">polymarket_bot.position</field>
        <field name="arch" type="xml">
            <list create="0"
                  decoration-danger="final_pnl &lt; 0"
                  decoration-success="final_pnl &gt; 0"
                  decoration-muted="not final_pnl">
                <field name="market_id"/>
                <field name="state" widget="badge"
                       decoration-muted="state in ['empty', 'closed']"
                       decoration-warning="state in ('one_side_yes','one_side_no')"
                       decoration-info="state == 'hedged'"
                       decoration-success="state == 'delta_neutral'"
                       decoration-danger="state == 'unhedged_expiry'"/>
                <field name="pair_cost"/>
                <field name="locked_profit"/>
                <field name="delta"/>
                <field name="projected_pnl_yes_wins" string="PNL if YES"/>
                <field name="projected_pnl_no_wins" string="PNL if NO"/>
                <field name="unhedged"/>
                <field name="final_pnl"/>
                <field name="winning_side" widget="badge"
                       decoration-success="winning_side == 'yes'"
                       decoration-danger="winning_side == 'no'"
                       decoration-muted="winning_side == 'unknown'"/>
                <field name="paper"/>
                <field name="opened_at"/>
            </list>
        </field>
    </record>

    <record id="view_polymarket_position_form" model="ir.ui.view">
        <field name="name">polymarket_bot.position.form</field>
        <field name="model">polymarket_bot.position</field>
        <field name="arch" type="xml">
            <form string="Position" create="0">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_market_price_chart"
                                class="oe_stat_button" icon="fa-line-chart"
                                invisible="not market_id">
                            <span class="o_stat_text">Price Chart</span>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="market_id"/>
                            <field name="paper"/>
                            <field name="unhedged"/>
                        </group>
                        <group>
                            <field name="market_end_time"/>
                            <field name="opened_at"/>
                            <field name="hedged_at"/>
                            <field name="delta_neutral_at"/>
                            <field name="closed_at"/>
                        </group>
                    </group>
                    <group string="Position Quantities">
                        <group string="YES Side">
                            <field name="qty_yes"/>
                            <field name="cost_yes"/>
                            <field name="avg_yes"/>
                        </group>
                        <group string="NO Side">
                            <field name="qty_no"/>
                            <field name="cost_no"/>
                            <field name="avg_no"/>
                        </group>
                    </group>
                    <group string="Computed Metrics">
                        <group>
                            <field name="delta"/>
                            <field name="pair_cost"/>
                            <field name="locked_profit"/>
                        </group>
                        <group>
                            <field name="projected_pnl_yes_wins" string="PNL if YES wins"/>
                            <field name="projected_pnl_no_wins" string="PNL if NO wins"/>
                            <field name="final_pnl"/>
                            <field name="winning_side"/>
                            <field name="result_label"/>
                        </group>
                    </group>
                    <group string="State Transition Log">
                        <field name="state_log" nolabel="1" widget="text"/>
                    </group>
                    <notebook>
                        <page string="Trades">
                            <field name="trade_ids">
                                <list>
                                    <field name="trade_time"/>
                                    <field name="side"/>
                                    <field name="trade_type"/>
                                    <field name="qty"/>
                                    <field name="price"/>
                                    <field name="cost"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_polymarket_positions" model="ir.actions.act_window">
        <field name="name">Positions</field>
        <field name="res_model">polymarket_bot.position</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_polymarket_open_positions" model="ir.actions.act_window">
        <field name="name">Open Positions</field>
        <field name="res_model">polymarket_bot.position</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'not in', ['closed'])]</field>
    </record>

</odoo>
