<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_polymarket" model="ir.module.category">
        <field name="name">Polymarket Bot</field>
        <field name="sequence">100</field>
    </record>

    <record id="group_polymarket_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_polymarket"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_polymarket_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_polymarket"/>
        <field name="implied_ids" eval="[(4, ref('group_polymarket_user'))]"/>
    </record>
</odoo>
